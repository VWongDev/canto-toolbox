{
  "name": "canto-toolbox",
  "version": "1.3.0",
  "description": "Hover over Chinese words to see definitions in Mandarin and Cantonese with pronunciations",
  "type": "module",
  "scripts": {
    "build:scripts": "tsc -p build-tools/tsconfig.json",
    "build:dict": "pnpm build:scripts && node build-tools/dist/build-tools/build-dictionaries.js",
    "build": "pnpm build:dict && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist public/data/mandarin.json public/data/cantonese.json public/data/etymology.json build-tools/dist",
    "screenshots": "pnpm build && pnpm build:scripts && node build-tools/dist/build-tools/generate-screenshots.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ build-tools/",
    "prepare": "husky"
  },
  "keywords": [
    "chrome-extension",
    "chinese",
    "dictionary",
    "mandarin",
    "cantonese"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.14.0",
    "eslint": "^10.2.0",
    "happy-dom": "^15.11.7",
    "husky": "^9.1.7",
    "puppeteer": "^24.37.5",
    "sharp": "^0.34.5",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.2",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
